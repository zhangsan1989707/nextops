{
  "name": "nextops",
  "version": "0.1.0",
  "private": true,
  "description": "NextOps AIOps and ChatOps operations platform",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "docker:up": "docker compose -f deploy/docker-compose.yml up --build",
    "docker:deploy": "docker compose -f deploy/docker-compose.yml up --build -d --remove-orphans",
    "docker:down": "docker compose -f deploy/docker-compose.yml down",
    "smoke": "sh scripts/smoke-test.sh",
    "agent:local": "npm run dev -w @nextops/agent",
    "nightly:codex": "zsh scripts/nightly-codex-dev.sh",
    "nightly:install": "zsh scripts/install-nightly-codex-launchd.sh"
  }
}
