# API 服务
PORT=4000
NODE_ENV=production

# 数据库
DATABASE_URL=postgres://nextops:nextops@postgres:5432/nextops

# Redis
REDIS_URL=redis://redis:6379

# AI 模型 (可选)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# JWT 密钥 (生产环境必须修改，建议用 openssl rand -base64 32 生成)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 数据加密密钥 (生产环境必须修改，建议用 openssl rand -base64 32 生成)
ENCRYPTION_KEY=your-encryption-key-change-in-production

# Agent Token (Agent 注册认证密钥，生产环境必须修改)
AGENT_TOKEN=your-agent-token-change-in-production

# 允许的 CORS 源 (逗号分隔，生产环境必须配置)
ALLOWED_ORIGINS=http://localhost:3019,https://your-domain.com

# 是否在启动时清理 demo 数据 (设为 true 启用，默认不清理)
CLEANUP_DEMO_DATA=false

# Agent 配置
NEXTOPS_API_URL=http://api:4000
NEXTOPS_AGENT_INTERVAL_MS=10000
